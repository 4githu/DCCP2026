   "source": [
    "def introduce(name, *hobbies):\n",
    "    hobbies_list = \", \".join(hobbies)\n",
    "    return f\"저는 {name}입니다. 취미는 {hobbies_list}입니다.\"\n",
    "\n",
    "print(introduce(\"영희\", \"독서\", \"영화\", \"요리\"))\n",
    "print(introduce(\"철수\", \"십자수\"))"
   ]
  }
 ],
